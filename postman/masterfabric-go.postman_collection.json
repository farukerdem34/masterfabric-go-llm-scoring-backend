									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Postgres is healthy', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.services.postgres).to.eql('healthy');",
									"});",
									"",
									"pm.test('Redis is healthy', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.services.redis).to.eql('healthy');",
									"});"
