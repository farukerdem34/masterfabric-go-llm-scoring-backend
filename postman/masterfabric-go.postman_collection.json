						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"{{user_password}}\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] },
						"description": "Authenticate and receive a JWT token (24h expiry). Token is automatically saved to `jwt_token` variable for all subsequent requests."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has JWT token', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.token).to.be.a('string').and.not.empty;",
									"    ",
									"    // Save token to BOTH collection and environment variables",
									"    pm.collectionVariables.set('jwt_token', json.token);",
									"    pm.environment.set('jwt_token', json.token);",
									"    ",
									"    console.log('✅ JWT token captured and saved to collection + environment');",
									"    console.log('Token preview: ' + json.token.substring(0, 30) + '...');",
									"});",
									"",
									"pm.test('Response has user info', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.user).to.be.an('object');",
									"    pm.expect(json.user.id).to.be.a('string');",
									"    ",
									"    // Save user_id to BOTH collection and environment",
									"    pm.collectionVariables.set('user_id', json.user.id);",
									"    pm.environment.set('user_id', json.user.id);",
									"    ",
									"    console.log('✅ User ID captured: ' + json.user.id);",
									"});",
									"",
									"pm.test('JWT is valid format (3 dot-separated parts)', function () {",
									"    var json = pm.response.json();",
									"    var parts = json.token.split('.');",
									"    pm.expect(parts).to.have.lengthOf(3);",
									"});"
								]
							}
						}
					]
