						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/health/live", "host": ["{{base_url}}"], "path": ["health", "live"] },
						"description": "Kubernetes-compatible liveness probe. Returns 200 if the process is alive."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Body contains alive status', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.status).to.eql('alive');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Readiness Probe",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/health/ready", "host": ["{{base_url}}"], "path": ["health", "ready"] },
						"description": "Readiness probe checking PostgreSQL and Redis connectivity."
					},
					"event": [
