		{
			"name": "Authentication (IAM)",
			"description": "User registration and login. Login auto-captures the JWT token for subsequent requests.",
			"item": [
				{
					"name": "Register User",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"{{user_password}}\",\n    \"first_name\": \"Admin\",\n    \"last_name\": \"User\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] },
						"description": "Register a new user. Returns user info (no token — login next). Publishes `user.registered` event to Kafka topic `masterfabric.iam`."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 201 Created', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has user ID', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.id).to.be.a('string').and.not.empty;",
									"    ",
									"    // Save to BOTH collection and environment",
									"    pm.collectionVariables.set('user_id', json.id);",
									"    pm.environment.set('user_id', json.id);",
									"    ",
									"    console.log('✅ User ID captured: ' + json.id);",
									"});",
									"",
									"pm.test('Email matches request', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.email).to.eql(pm.collectionVariables.get('user_email'));",
									"});",
									"",
									"pm.test('Status is active', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.status).to.eql('active');",
									"});"
								]
							}
						}
					]
				},
